# Quinn — Environment Variables
# Copy to .env and fill in your values

# Infisical (preferred — pulls all secrets at startup)
# Generate a service token: infisical login --domain https://secrets.proto-labs.ai
# Then: infisical service-token create --projectId 11e172e0-a1f6-41d5-9464-df72779a7063
INFISICAL_TOKEN=
INFISICAL_API_URL=https://secrets.proto-labs.ai
INFISICAL_PROJECT_ID=11e172e0-a1f6-41d5-9464-df72779a7063
INFISICAL_ENVIRONMENT=prod

# Fallback: direct env vars (only needed if Infisical is not configured)
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=
# DISCORD_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=

# protoLabs Studio API
PROTOLABS_SERVER_URL=http://host.docker.internal:3008
PROTOLABS_API_KEY=

# Langfuse tracing (optional)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://host.docker.internal:3001
