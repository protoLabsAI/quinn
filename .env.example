# Quinn — Environment Variables
#
# Secrets are managed via Infisical. Start Quinn with:
#   cd ~/dev/quinn
#   INFISICAL_API_URL=https://secrets.proto-labs.ai infisical run --env prod -- docker compose up
#
# This injects all 24 secrets from Infisical as env vars before docker compose starts.
# No .env file needed for secrets.

# protoLabs Studio API (not in Infisical — local config)
PROTOLABS_SERVER_URL=http://host.docker.internal:3008
PROTOLABS_API_KEY=
